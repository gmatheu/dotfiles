# Plugin Manager Loading Logic
load_plugins() {
  case "${ZSH_PLUGIN_MANAGER}" in
  antidote)
    if [[ -v SKIP_ANTIDOTE ]]; then
      echo "Skipping antidote (SKIP_ANTIDOTE is set)"
    else
      load_antidote
      apply_antidote_bundles
    fi
    ;;
  sheldon)
    if [[ -v SKIP_SHELDON ]]; then
      echo "Skipping sheldon (SKIP_SHELDON is set)"
    else
      load_sheldon
      apply_sheldon_bundles
    fi
    ;;
  zplug | *)
    # Default to zplug for backward compatibility
    if [[ -v SKIP_ZPLUG ]]; then
      echo "Skipping zplug (SKIP_ZPLUG is set)"
    else
      load_zplug
      apply_zplug_bundles
    fi
    ;;
  esac
}

