export ZPLUG_HOME=${HOME}/.zplug
# export ZPLUG_VERSION=2.4.2
function load_zplug() {
  ZPLUG_FILE="$ZPLUG_HOME/init.zsh"
  if [ ! -f $ZPLUG_FILE ]; then
    curl -sL --proto-redir -all,https https://raw.githubusercontent.com/zplug/installer/main/installer.zsh | zsh
  fi
  source $ZPLUG_FILE
}

# Antidote - Modern, fast zsh plugin manager
export ANTIDOTE_HOME=${HOME}/.antidote
function load_antidote() {
  if [ ! -d $ANTIDOTE_HOME ]; then
    echo 'Installing antidote...'
    git clone --depth=1 https://github.com/mattmc3/antidote.git ${ANTIDOTE_HOME}
  fi
  # echo "Loading antidote"
  source ${ANTIDOTE_HOME}/antidote.zsh
}

# Sheldon - Fast, configurable shell plugin manager
export SHELDON_CONFIG_DIR=${HOME}/.config/sheldon
export SHELDON_CONFIG_FILE=${SHELDON_CONFIG_DIR}/plugins.toml
function load_sheldon() {
  if ! command -v sheldon &>/dev/null; then
    echo 'sheldon not found. Install via: cargo install sheldon or download from https://github.com/rossmacarthur/sheldon/releases'
    return 1
  fi
  if [ ! -f $SHELDON_CONFIG_FILE ]; then
    echo 'Initializing sheldon config...'
    mkdir -p $SHELDON_CONFIG_DIR
    sheldon init --shell zsh
  fi
  eval "$(sheldon source)"
}

bind_keys() {
  # Vi-mode
  export KEYTIMEOUT=1
  bindkey -e
  bindkey "^[[1;3C" forward-word
  bindkey "^[[1;3D" backward-word
  bindkey "^R" history-incremental-search-backward
  bindkey "^?" backward-delete-char
  bindkey "^F" forward-char # Make them work in vicmd
  bindkey "^D" delete-char-or-list
  bindkey "^a" beginning-of-line
  bindkey "^e" end-of-line
  bindkey "^f" history-incremental-search-forward
  bindkey "^g" send-break
  bindkey "^h" backward-delete-char
  bindkey "^n" down-history
  bindkey "^p" up-history
  bindkey "^r" history-incremental-search-backward
  bindkey "^u" redo
  bindkey "^w" backward-kill-word
  bindkey "^?" backward-delete-char

  export WORDCHARS='*?_~=&;!#$%^{}<>'
  autoload -Uz select-word-style
  select-word-style normal
}

