# Antidote bundle configuration - generates .zsh_plugins.txt
function apply_antidote_bundles() {
  if ! command -v antidote &>/dev/null; then
    return 1
  fi

  antidote load
}

# Sheldon bundle configuration - generates plugins.toml
function apply_sheldon_bundles() {
  if ! command -v sheldon &>/dev/null; then
    return 1
  fi

  eval "$(sheldon source)"
}

