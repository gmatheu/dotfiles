# Plugin Manager Configuration
# Set to 'zplug', 'antidote', or 'sheldon' to choose plugin manager
# Examples:
#   export ZSH_PLUGIN_MANAGER=zplug
#   export ZSH_PLUGIN_MANAGER=sheldon
